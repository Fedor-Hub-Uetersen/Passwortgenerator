<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Генератор паролей</title>
    <style>
        body {
            font-family: 'Arial', sans-serif;
            background-color: #f4f4f9;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .container {
            background: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            width: 350px;
            text-align: center;
        }
        /* Стили для круглого логотипа программы */
        .app-logo {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            object-fit: cover;
            margin-bottom: 20px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.15);
            border: 3px solid #008CBA;
        }
        input[type="text"] {
            width: 90%;
            padding: 10px;
            font-size: 18px;
            text-align: center;
            margin-bottom: 20px;
            border: 1px solid #ccc;
            border-radius: 5px;
        }
        .setting {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
            font-size: 15px;
        }
        .setting input[type="checkbox"] {
            width: 18px;
            height: 18px;
        }
        .setting input[type="range"] {
            width: 60%;
        }
        button {
            width: 100%;
            padding: 12px;
            font-size: 16px;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            margin-top: 10px;
            transition: background 0.2s;
        }
        .btn-generate { background-color: #4CAF50; }
        .btn-generate:hover { background-color: #45a049; }
        .btn-copy { background-color: #008CBA; }
        .btn-copy:hover { background-color: #007bb5; }
    </style>
</head>
<body>

<div class="container">
    <img src="images/logo.png" alt="Логотип Генератора Паролей" class="app-logo">

    <input type="text" id="passwordDisplay" placeholder="Здесь будет пароль" readonly>
    
    <div class="setting">
        <label>Длина (<span id="lengthValue">12</span>):</label>
        <input type="range" id="passwordLength" min="8" max="24" value="12" oninput="document.getElementById('lengthValue').innerText = this.value">
    </div>
    
    <div class="setting">
        <label>Буквы (A-Z, a-z)</label>
        <input type="checkbox" id="includeLetters" checked>
    </div>
    
    <div class="setting">
        <label>Цифры (0-9)</label>
        <input type="checkbox" id="includeDigits" checked>
    </div>
    
    <div class="setting">
        <label>Спецсимволы (%@#!)</label>
        <input type="checkbox" id="includeSpecials" checked>
    </div>

    <button class="btn-generate" onclick="generatePassword()">Сгенерировать</button>
    <button class="btn-copy" onclick="copyToClipboard()">Копировать в буфер</button>
</div>

<script>
// Функция для красивого форматирования времени в логах
function getTimestamp() {
    const now = new Date();
    return now.toLocaleTimeString('ru-RU') + '.' + String(now.getMilliseconds()).padStart(3, '0');
}

function generatePassword() {
    const length = document.getElementById('passwordLength').value;
    const includeLetters = document.getElementById('includeLetters').checked;
    const includeDigits = document.getElementById('includeDigits').checked;
    const includeSpecials = document.getElementById('includeSpecials').checked;

    let allCharacters = "";
    if (includeLetters) allCharacters += "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ";
    if (includeDigits) allCharacters += "0123456789";
    if (includeSpecials) allCharacters += "!\"#$%&'()*+,-./:;<=>?@[\\]^_`{|}~";

    if (!allCharacters) {
        console.warn(`[${getTimestamp()}] [ОШИБКА] Попытка генерации без выбранных наборов символов.`);
        alert("Внимание! Выберите хотя бы один тип символов!");
        return;
    }

    let generatedPassword = "";
    for (let i = 0; i < length; i++) {
        const randomIndex = Math.floor(Math.random() * allCharacters.length);
        generatedPassword += allCharacters[randomIndex];
    }

    document.getElementById('passwordDisplay').value = generatedPassword;
    
    // Запись в лог
    console.log(`[${getTimestamp()}] [ИНФО] Сгенерирован пароль длиной ${length}. Настройки: Буквы=${includeLetters}, Цифры=${includeDigits}, Спецы=${includeSpecials}`);
}

function copyToClipboard() {
    const passwordField = document.getElementById('passwordDisplay');
    if (passwordField.value) {
        navigator.clipboard.writeText(passwordField.value);
        console.log(`[${getTimestamp()}] [УСПЕХ] Пароль успешно скопирован в буфер обмена.`);
        alert("Успех! Пароль скопирован в буфер обмена!");
    } else {
        console.warn(`[${getTimestamp()}] [ВНИМАНИЕ] Попытка копирования пустого пароля.`);
        alert("Внимание! Сначала сгенерируйте пароль!");
    }
}

// Стартовый лог при загрузке страницы
console.log(`[${getTimestamp()}] [СИСТЕМА] Генератор паролей успешно запущен и готов к работе.`);
</script>

</body>
</html>